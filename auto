        }
    
    def _calculate_base_value(self, details: Dict) -> float:
        """Calcula valor base do veículo"""
        # Tabela FIPE simulada
        make = details.get("make", "")
        model = details.get("model", "")
        year = details.get("year", 2020)
        
        # Simulação simples
        base_prices = {
            "Toyota Corolla": 120000,
            "Honda Civic": 115000,
            "VW Golf": 110000,
            "Jeep Compass": 140000
        }
        
        return base_prices.get(f"{make} {model}", 100000) * (1 - (2025 - year) * 0.1)
    
    def _evaluate_condition(self, condition: Dict) -> float:
        """Avalia condição do veículo e retorna multiplicador"""
        condition_multipliers = {
            "excellent": 1.0,
            "good": 0.95,
            "fair": 0.85,
            "poor": 0.7
        }
        
        overall = condition.get("overall", "good")
        return condition_multipliers.get(overall, 0.9)
    
