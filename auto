# agents/atlas.py
from typing import Dict, Any, Optional, List
import asyncio
from datetime import datetime, timedelta
import numpy as np
from collections import defaultdict

class AtlasAgent:
    """
    ATLAS - Agente Coordenador e Estrategista
    Responsável por orquestrar todos os outros agentes e tomar decisões estratégicas
    """
    
    def __init__(self):
        self.agent_status = {}
        self.system_metrics = defaultdict(list)
        self.pricing_strategies = {}
        self.featured_listings = []
        
    async def initialize(self):
        """Inicializa o agente coordenador"""
        print("🗺️ ATLAS: Agente coordenador inicializado e orquestrando o sistema!")
        return True
        
    async def shutdown(self):
        """Desliga o agente"""
        print("🗺️ ATLAS: Agente coordenador desligado.")
        return True
    
    async def get_featured_listings(self) -> List[Dict]:
        """Seleciona veículos em destaque baseado em múltiplos critérios"""
        
        # Busca todos os anúncios ativos
        all_listings = await self._get_active_listings()
        
        # Calcula scores para cada anúncio
        scored_listings = []
        for listing in all_listings:
            score = await self._calculate_listing_score(listing)
            scored_listings.append({
                **listing,
                "feature_score": score
            })
        
        # Ordena por score e pega os top 10
        scored_listings.sort(key=lambda x: x["feature_score"], reverse=True)
        self.featured_listings = scored_listings[:10]
        
        return self.featured_listings
    
    async def get_recommendations(self, user_id: str) -> List[Dict]:
        """Gera recomendações personalizadas para o usuário"""
        
        # Obtém perfil do usuário
        user_profile = await self._get_user_profile(user_id)
        
        # Obtém histórico de interações
        user_history = await self._get_user_history(user_id)
        
        # Busca veículos disponíveis
        available_vehicles = await self._get_available_vehicles()
        
        # Calcula scores de recomendação
        recommendations = []
        for vehicle in available_vehicles:
            score = self._calculate_recommendation_score(vehicle, user_profile, user_history)
            if score > 0.5:  # Threshold mínimo
                recommendations.append({
                    "vehicle": vehicle,
                    "score": score,
                    "reason": self._generate_recommendation_reason(vehicle, user_profile)
                })
        
        # Ordena por score
        recommendations.sort(key=lambda x: x["score"], reverse=True)
        
        return recommendations[:5]  # Top 5 recomendações
    
    async def orchestrate_agents(self, task: Dict) -> Dict:
        """Orquestra múltiplos agentes para completar uma tarefa complexa"""
        
        task_id = f"task_{int(datetime.now().timestamp())}"
        result = {
            "task_id": task_id,
            "status": "processing",
            "agents_involved": [],
            "results": {},
            "completed_at": None
        }
        
        # Determina quais agentes são necessários
        required_agents = self._determine_required_agents(task)
        result["agents_involved"] = required_agents
        
        # Executa tarefas em paralelo quando possível
        tasks = []
        for agent in required_agents:
            if agent == "nova":
                tasks.append(self._call_nova(task))
            elif agent == "spectre":
                tasks.append(self._call_spectre(task))
            elif agent == "orion":
                tasks.append(self._call_orion(task))
            elif agent == "trade":
                tasks.append(self._call_trade(task))
        
        # Aguarda todas as tarefas
        agent_results = await asyncio.gather(*tasks, return_exceptions=True)
        
        # Compila resultados
        for agent, agent_result in zip(required_agents, agent_results):
            if isinstance(agent_result, Exception):
                result["results"][agent] = {"error": str(agent_result)}
            else:
                result["results"][agent] = agent_result
        
        # Coordena decisão final
        result["final_decision"] = await self._make_final_decision(result)
        result["status"] = "completed"
        result["completed_at"] = datetime.now().isoformat()
        
        return result
    
    async def optimize_pricing(self, vehicle_id: str) -> Dict[str, Any]:
        """Otimiza preço baseado em dados de mercado em tempo real"""
        
        # Coleta dados de múltiplas fontes
        market_data = await self._get_market_data(vehicle_id)
        competitor_prices = await self._get_competitor_prices(vehicle_id)
        demand_data = await self._get_demand_data(vehicle_id)
        
        # Calcula preço otimizado
        base_price = market_data.get("avg_price", 0)
        competitor_factor = self._calculate_competitor_factor(competitor_prices, base_price)
        demand_factor = self._calculate_demand_factor(demand_data)
        
        optimized_price = base_price * competitor_factor * demand_factor
        
        # Aplica estratégia de precificação
        strategy = self._select_pricing_strategy(vehicle_id, optimized_price)
        
        return {
            "vehicle_id": vehicle_id,
            "original_price": base_price,
            "optimized_price": round(optimized_price, 2),
            "market_data": market_data,
            "competitor_analysis": competitor_prices,
            "demand_analysis": demand_data,
            "strategy": strategy,
            "recommendation": self._generate_price_recommendation(optimized_price, strategy)
        }
    
    async def monitor_system_health(self) -> Dict[str, Any]:
        """Monitora a saúde de todo o sistema"""
        
        health_report = {
            "timestamp": datetime.now().isoformat(),
            "agents": {},
            "performance": {},
            "alerts": []
        }
        
        # Verifica status de cada agente
        agents = ["nova", "spectre", "orion", "trade"]
        for agent in agents:
            status = self.agent_status.get(agent, {})
            health_report["agents"][agent] = {
                "status": status.get("status", "unknown"),
                "last_active": status.get("last_active"),
                "tasks_completed": status.get("tasks_completed", 0),
                "error_rate": status.get("error_rate", 0)
            }
            
            # Gera alertas se necessário
