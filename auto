        """Ajusta valor baseado na quilometragem"""
        expected_mileage = (2025 - year) * 15000  # 15k km por ano
        
        if mileage <= expected_mileage:
            return 1.0
        elif mileage <= expected_mileage * 1.2:
            return 0.95
        elif mileage <= expected_mileage * 1.5:
            return 0.9
        else:
            return 0.85
    
