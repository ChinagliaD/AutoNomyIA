            "avg_response_time": np.mean(self.system_metrics.get("response_times", [100])),
            "requests_per_minute": len(self.system_metrics.get("recent_requests", [])),
            "success_rate": 1 - (len(self.system_metrics.get("errors", [])) / max(len(self.system_metrics.get("requests", [])), 1))
        }
        
