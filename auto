### **agents/orchestrator.py**
```python
# agents/orchestrator.py
from typing import Dict, Any, Optional
import asyncio
from datetime import datetime
import uuid
from .nova import NovaAgent
from .spectre import SpectreAgent
from .orion import OrionAgent
from .trade import TradeAgent
from .atlas import AtlasAgent

class AgentOrchestrator:
    """
    Orquestrador Principal - Gerencia todos os agentes e coordena o fluxo de trabalho
    """
    
    def __init__(self):
        self.sessions = {}
        self.agents = {
            "nova": NovaAgent(),
            "spectre": SpectreAgent(),
            "orion": OrionAgent(),
            "trade": TradeAgent(),
            "atlas": AtlasAgent()
        }
        self.active_tasks = {}
        
    async def initialize_all(self):
        """Inicializa todos os agentes"""
        print("🚀 Inicializando todos os agentes...")
        for name, agent in self.agents.items():
            await agent.initialize()
            print(f"✅ {name.upper()} inicializado")
        
        print("🎉 Todos os agentes estão prontos para operar!")
        
    async def process_message(self, session_id: str, message: str, user_id: Optional[str] = None) -> Dict[str, Any]:
        """Processa mensagem do usuário usando o agente apropriado"""
        
        # Cria nova sessão se não existir
        if session_id not in self.sessions:
            self.sessions[session_id] = {
                "session_id": session_id,
                "user_id": user_id,
                "created_at": datetime.now().isoformat(),
                "context": {},
                "preferred_agent": None
            }
        
        session = self.sessions[session_id]
        
        # Determina qual agente deve responder
        agent_name = await self._select_agent(message, session)
        session["preferred_agent"] = agent_name
        
        # Obtém o agente
        agent = self.agents[agent_name]
        
        # Processa a mensagem
        start_time = datetime.now()
        response = await agent.process_message(session_id, message, user_id)
        processing_time = (datetime.now() - start_time).total_seconds()
        
        # Enriquece a resposta com metadados
        response.update({
            "processing_time": processing_time,
            "agent_used": agent_name,
            "session_id": session_id
        })
        
        # Atualiza contexto da sessão
        session["last_interaction"] = datetime.now().isoformat()
        session["context"]["last_message"] = message
        session["context"]["last_response"] = response
        
        return response
    
    async def execute_task(self, task: Dict) -> Dict[str, Any]:
        """Executa uma tarefa complexa usando múltiplos agentes"""
        
        task_id = str(uuid.uuid4())
        self.active_tasks[task_id] = {
            "task": task,
            "status": "running",
            "started_at": datetime.now().isoformat()
        }
        
        try:
            # Usa o ATLAS para orquestrar a tarefa
            result = await self.agents["atlas"].orchestrate_agents(task)
            
            self.active_tasks[task_id]["status"] = "completed"
            self.active_tasks[task_id]["result"] = result
            self.active_tasks[task_id]["completed_at"] = datetime.now().isoformat()
            
            return result
            
        except Exception as e:
            self.active_tasks[task_id]["status"] = "failed"
            self.active_tasks[task_id]["error"] = str(e)
            raise
    
    async def get_system_status(self) -> Dict[str, Any]:
        """Retorna o status de todo o sistema"""
        
        status = {
            "timestamp": datetime.now().isoformat(),
            "agents": {},
            "sessions": {
                "total": len(self.sessions),
                "active": sum(1 for s in self.sessions.values() 
                            if (datetime.now() - datetime.fromisoformat(s.get("last_interaction", "2000-01-01"))).seconds < 300)
            },
            "tasks": {
                "active": sum(1 for t in self.active_tasks.values() if t["status"] == "running"),
                "completed": sum(1 for t in self.active_tasks.values() if t["status"] == "completed"),
                "failed": sum(1 for t in self.active_tasks.values() if t["status"] == "failed")
            }
        }
        
        # Coleta status de cada agente
        for name, agent in self.agents.items():
            try:
                if hasattr(agent, 'get_status'):
                    status["agents"][name] = await agent.get_status()
                else:
                    status["agents"][name] = {"status": "available"}
            except:
                status["agents"][name] = {"status": "error"}
        
        return status
    
    async def _select_agent(self, message: str, session: Dict) -> str:
        """Seleciona o agente mais apropriado para responder"""
        
        message_lower = message.lower()
        
        # Palavras-chave para cada agente
        agent_keywords = {
            "nova": ["quero comprar", "preço", "negociar", "financiamento", "test drive", "qual o valor"],
            "spectre": ["comparar", "especificações", "ficha técnica", "consumo", "desempenho", "vs"],
            "orion": ["agendar", "documentos", "papelada", "cadastrar", "publicar", "anunciar"],
            "trade": ["vender", "trocar", "avaliar", "quanto vale", "proposta"]
        }
        
        # Verifica se há match com algum agente específico
        for agent, keywords in agent_keywords.items():
            if any(keyword in message_lower for keyword in keywords):
                return agent
        
        # Se não houver match claro, usa o último agente ou NOVA como padrão
        return session.get("preferred_agent", "nova")
    
    async def shutdown_all(self):
        """Desliga todos os agentes graciosamente"""
        print("🔄 Desligando todos os agentes...")
        for name, agent in self.agents.items():
            await agent.shutdown()
            print(f"✅ {name.upper()} desligado")
