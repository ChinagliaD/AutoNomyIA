from motor.motor_asyncio import AsyncIOMotorClient
from typing import Optional, Dict, Any, List
import os
from datetime import datetime
import json

class DatabaseConnection:
    """
    Gerenciador de conexão com MongoDB
    """
    
    def __init__(self):
        self.client: Optional[AsyncIOMotorClient] = None
        self.db = None
        self.connection_string = os.getenv("MONGODB_URI", "mongodb://localhost:27017")
        self.db_name = os.getenv("DB_NAME", "autonomy")
        
    async def connect(self):
        """Estabelece conexão com o banco de dados"""
        try:
            self.client = AsyncIOMotorClient(self.connection_string)
            self.db = self.client[self.db_name]
            
            # Verifica conexão
            await self.client.admin.command('ping')
            print(f"✅ Conectado ao MongoDB: {self.db_name}")
            
            # Cria índices
            await self._create_indexes()
            
        except Exception as e:
            print(f"❌ Erro ao conectar ao MongoDB: {e}")
            raise
    
    async def disconnect(self):
        """Fecha conexão com o banco de dados"""
        if self.client:
            self.client.close()
            print("✅ Desconectado do MongoDB")
    
    async def _create_indexes(self):
        """Cria índices necessários"""
        # Índices para veículos
        await self.db.vehicles.create_index("vin", unique=True)
        await self.db.vehicles.create_index("make")
        await self.db.vehicles.create_index("model")
        await self.db.vehicles.create_index("year")
        
        # Índices para usuários
        await self.db.users.create_index("email", unique=True)
        await self.db.users.create_index("phone")
        
        # Índices para anúncios
        await self.db.listings.create_index("vehicle_id")
        await self.db.listings.create_index("user_id")
        await self.db.listings.create_index([("price", 1), ("created_at", -1)])
    
    # Métodos CRUD para Veículos
    async def insert_vehicle(self, vehicle_data: Dict) -> str:
        """Insere um novo veículo"""
        vehicle_data["created_at"] = datetime.now()
        vehicle_data["updated_at"] = datetime.now()
        
        result = await self.db.vehicles.insert_one(vehicle_data)
        return str(result.inserted_id)
    
    async def get_vehicle(self, vehicle_id: str) -> Optional[Dict]:
        """Busca um veículo por ID"""
        from bson.objectid import ObjectId
        return await self.db.vehicles.find_one({"_id": ObjectId(vehicle_id)})
    
    async def search_vehicles(self, query: Dict) -> List[Dict]:
        """Busca veículos com filtros"""
        cursor = self.db.vehicles.find(query)
        return await cursor.to_list(length=100)
    
    # Métodos CRUD para Usuários
    async def insert_user(self, user_data: Dict) -> str:
        """Insere um novo usuário"""
        user_data["created_at"] = datetime.now()
        user_data["updated_at"] = datetime.now()
        
        result = await self.db.users.insert_one(user_data)
        return str(result.inserted_id)
    
    async def get_user(self, user_id: str) -> Optional[Dict]:
        """Busca um usuário por ID"""
        from bson.objectid import ObjectId
        return await self.db.users.find_one({"_id": ObjectId(user_id)})
    
    async def get_user_by_email(self, email: str) -> Optional[Dict]:
        """Busca um usuário por email"""
        return await self.db.users.find_one({"email": email})
    
    # Métodos CRUD para Anúncios
    async def create_listing(self, listing_data: Dict) -> str:
        """Cria um novo anúncio"""
        listing_data["created_at"] = datetime.now()
        listing_data["updated_at"] = datetime.now()
        listing_data["status"] = "active"
        listing_data["views"] = 0
        listing_data["inquiries"] = 0
        
        result = await self.db.listings.insert_one(listing_data)
        return str(result.inserted_id)
    
    async def get_listings(self, filters: Dict, page: int = 1, per_page: int = 20) -> List[Dict]:
        """Busca anúncios com paginação"""
        skip = (page - 1) * per_page
        
        cursor = self.db.listings.find(filters).sort("created_at", -1).skip(skip).limit(per_page)
        return await cursor.to_list(length=per_page)
    
    async def update_listing(self, listing_id: str, updates: Dict) -> bool:
        """Atualiza um anúncio"""
        from bson.objectid import ObjectId
        updates["updated_at"] = datetime.now()
        
        result = await self.db.listings.update_one(
            {"_id": ObjectId(listing_id)},
            {"$set": updates}
        )
        return result.modified_count > 0
    
    # Métodos para Transações
    async def create_transaction(self, transaction_data: Dict) -> str:
        """Registra uma transação"""
        transaction_data["created_at"] = datetime.now()
        transaction_data["status"] = "pending"
        
        result = await self.db.transactions.insert_one(transaction_data)
        return str(result.inserted_id)
    
    async def update_transaction(self, transaction_id: str, status: str) -> bool:
        """Atualiza status de uma transação"""
        from bson.objectid import ObjectId
        
        result = await self.db.transactions.update_one(
            {"_id": ObjectId(transaction_id)},
            {
                "$set": {
                    "status": status,
                    "updated_at": datetime.now()
                }
            }
        )
        return result.modified_count > 0
    
    # Métodos para Analytics
    async def track_event(self, event_data: Dict) -> None:
        """Registra um evento para analytics"""
        event_data["timestamp"] = datetime.now()
        await self.db.events.insert_one(event_data)
    
    async def get_analytics(self, metric: str, start_date: datetime, end_date: datetime) -> List[Dict]:
        """Busca dados de analytics"""
        pipeline = [
            {
                "$match": {
                    "timestamp": {"$gte": start_date, "$lte": end_date}
                }
            },
            {
                "$group": {
                    "_id": {"$dateToString": {"format": "%Y-%m-%d", "date": "$timestamp"}},
                    "count": {"$sum": 1}
                }
            },
            {"$sort": {"_id": 1}}
        ]
        
        cursor = self.db.events.aggregate(pipeline)
        return await cursor.to_list(length=None)
