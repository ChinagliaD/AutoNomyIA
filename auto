        if lead_data.get("owns_vehicle"):
            vehicle_age = lead_data.get("vehicle_age", 0)
            if vehicle_age > 3:
                factors["vehicle_age"] = 30
                score += 30
        
        # Score baseado em histórico de compras
        if lead_data.get("past_purchases") and lead_data["past_purchases"] > 0:
            factors["past_purchases"] = 25
            score += 25
        
        lead_score = {
            "lead_id": lead_data.get("id"),
            "total_score": score,
            "factors": factors,
            "category": self._get_lead_category(score),
