from langchain.agents import Tool, AgentExecutor, create_react_agent
from langchain.prompts import PromptTemplate
import os
from dotenv import load_dotenv

load_dotenv()

class NovaAgent:
    """
    NOVA - Agente de Vendas e Negociação
    Personalidade: Amigável, persuasiva, especialista em vendas
    """
    
    def __init__(self):
        self.llm = ChatOpenAI(
            temperature=0.8,
            model_name="gpt-4o",
            api_key=os.getenv("OPENAI_API_KEY")
        )
        self.memories = {}  # session_id -> memory
        self.active_negotiations = {}
        
    async def initialize(self):
        """Inicializa o agente"""
        print("🤝 NOVA: Agente de vendas inicializado e pronta para atender!")
        return True
        
    async def shutdown(self):
        """Desliga o agente"""
        print("🤝 NOVA: Agente de vendas desligado.")
        return True
    
    async def process_message(self, session_id: str, message: str, user_id: Optional[str] = None) -> Dict[str, Any]:
        """Processa mensagem do usuário"""
        
        # Obtém ou cria memória para a sessão
        if session_id not in self.memories:
            self.memories[session_id] = ConversationBufferMemory(
                memory_key="chat_history",
                return_messages=True
            )
        
        memory = self.memories[session_id]
        
        # Template de prompt para a NOVA
        prompt = PromptTemplate.from_template("""
        Você é a NOVA, uma agente de IA especializada em vendas de veículos. 
        Você é amigável, persuasiva e extremamente conhecedora do mercado automotivo.
        
        Histórico da conversa:
        {chat_history}
        
        Mensagem do usuário: {input}
        
        Responda de forma natural, identificando necessidades e guiando o usuário 
        para encontrar o veículo perfeito. Seja entusiástica mas profissional.
        Sempre busque qualificar o lead e entender orçamento, preferências e necessidades.
        
        Resposta da NOVA:
        """)
        
        # Cria agente com ferramentas
        tools = [
            Tool(name="search_vehicles", func=self._search_vehicles, 
                 description="Busca veículos no inventário"),
            Tool(name="calculate_financing", func=self._calculate_financing,
                 description="Calcula opções de financiamento"),
            Tool(name="get_vehicle_details", func=self._get_vehicle_details,
                 description="Obtém detalhes completos de um veículo"),
        ]
        
        agent = create_react_agent(self.llm, tools, prompt)
        agent_executor = AgentExecutor(agent=agent, tools=tools, verbose=True)
        
        # Executa o agente
        response = await agent_executor.ainvoke({
            "input": message,
            "chat_history": memory.buffer
        })
        
        # Salva na memória
        memory.save_context({"input": message}, {"output": response["output"]})
        
        # Detecta intenção de compra
        buying_intent = self._detect_buying_intent(message, response["output"])
        
        return {
            "agent": "NOVA",
            "response": response["output"],
            "session_id": session_id,
            "timestamp": datetime.now().isoformat(),
            "buying_intent": buying_intent,
            "suggested_actions": self._suggest_next_actions(buying_intent)
        }
    
    async def negotiate(self, listing_id: str, user_id: str, proposed_price: float) -> Dict[str, Any]:
        """Negocia preço com o comprador"""
        
        # Simula uma negociação inteligente
        listing_price = await self._get_listing_price(listing_id)
        min_price = listing_price * 0.9  # Preço mínimo (10% abaixo)
        
        # Estratégia de negociação da NOVA
        counter_offer = None
        status = "em_andamento"
        
        if proposed_price >= listing_price * 0.95:
            # Proposta muito boa, aceita
            counter_offer = proposed_price
            status = "aceita"
            message = "Excelente proposta! Fechamos negócio! 🎉"
        elif proposed_price >= min_price:
            # Proposta razoável, faz contra-proposta
            counter_offer = (proposed_price + listing_price) / 2
            status = "contra_proposta"
            message = f"Que tal encontrarmos um meio termo em R$ {counter_offer:,.2f}?"
        else:
            # Proposta muito baixa, recusa educadamente
            status = "recusada"
            message = f"Infelizmente não posso aceitar esse valor. O melhor que posso fazer é R$ {min_price:,.2f}."
        
        negotiation = {
            "negotiation_id": f"neg_{listing_id}_{user_id}",
            "listing_id": listing_id,
            "user_id": user_id,
            "proposed_price": proposed_price,
            "counter_offer": counter_offer,
            "status": status,
            "message": message,
            "agent": "NOVA",
            "timestamp": datetime.now().isoformat()
        }
        
        self.active_negotiations[negotiation["negotiation_id"]] = negotiation
        return negotiation
    
    def _search_vehicles(self, query: str) -> str:
        """Busca veículos (simulado)"""
        # Aqui seria integrado com o banco de dados real
        return f"Encontrei 5 veículos que correspondem à sua busca por '{query}'"
    
    def _calculate_financing(self, vehicle_price: float, down_payment: float, months: int) -> str:
        """Calcula financiamento"""
        interest_rate = 0.015  # 1.5% ao mês
        financed_amount = vehicle_price - down_payment
        monthly_payment = financed_amount * (interest_rate * (1 + interest_rate) ** months) / ((1 + interest_rate) ** months - 1)
        
        return f"Para financiar R$ {financed_amount:,.2f} em {months}x, as parcelas seriam de R$ {monthly_payment:,.2f}"
    
    def _get_vehicle_details(self, vehicle_id: str) -> str:
        """Obtém detalhes do veículo"""
        # Simulado - integrar com banco de dados real
        return f"Detalhes completos do veículo {vehicle_id}..."
    
    def _detect_buying_intent(self, message: str, response: str) -> Dict[str, Any]:
        """Detecta intenção de compra na conversa"""
        buying_keywords = ["comprar", "quero", "preço", "negociar", "fechar", "parcelas", "financiamento"]
        
        intent_score = 0
        for keyword in buying_keywords:
            if keyword in message.lower():
                intent_score += 0.2
        
        return {
            "score": min(intent_score, 1.0),
            "ready_to_buy": intent_score >= 0.6,
            "needs_financing": "financiamento" in message.lower() or "parcelas" in message.lower()
        }
    
    def _suggest_next_actions(self, buying_intent: Dict[str, Any]) -> List[str]:
        """Sugere próximas ações baseado na intenção"""
        actions = []
        
        if buying_intent["score"] < 0.3:
            actions.append("Mostrar veículos em destaque")
            actions.append("Perguntar sobre preferências")
        elif buying_intent["score"] < 0.6:
            actions.append("Agendar test drive")
            actions.append("Oferecer comparação de modelos")
        else:
            actions.append("Iniciar negociação de preço")
            if buying_intent["needs_financing"]:
                actions.append("Calcular opções de financiamento")
            actions.append("Preparar proposta")
        
        return actions
    
